# GhanaRide Environment Variables
# Copy this file to .env or set these in your OS environment variables

# --- Database ---
# If not set, defaults to a local MySQL instance
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3307/ghanaride?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-db-password

# --- Email (SMTP) ---
# Used for sending verification and welcome emails
MAIL_USERNAME=noreply.ghanaride@gmail.com
# For Gmail, use an App Password, NOT your real password
MAIL_PASSWORD=your-app-password

# --- Base URL ---
# Must match where your app is hosted (used for email links and OAuth redirects)
APP_BASE_URL=http://localhost:8088

# --- Google OAuth2 ---
# Used for "Sign in with Google" feature
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Paystack (Payments) ---
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key
