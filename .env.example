# GhanaRide local environment variables
# Copy to .env or define in your OS / IntelliJ Run Configuration.

# Database
DB_URL=jdbc:mysql://localhost:3306/ghanaride?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root

# App URL
APP_BASE_URL=http://localhost:8088

# Default admin password override (optional)
ADMIN_PASSWORD=Admin@12345

# MailHog / local SMTP (optional)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=noreply@ghanaride.local
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=noreply@ghanaride.local
MAIL_REPLY_TO=support@ghanaride.local

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=mock-google-client-id
GOOGLE_CLIENT_SECRET=mock-google-client-secret

# Paystack test keys
PAYSTACK_SECRET_KEY=sk_test_mock_key
PAYSTACK_PUBLIC_KEY=pk_test_mock_key
PAYSTACK_WEBHOOK_SECRET=test_webhook_secret
